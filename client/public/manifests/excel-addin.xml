<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">
  <Id>73f41e37-23c8-4a24-bb23-f72e7f7319e8</Id>
  <Version>2.1.0</Version>
  <ProviderName>Bruce Gillingham Pollard</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="ChatBGP for Excel v2"/>
  <Description DefaultValue="AI-powered Excel assistant with CRM integration, financial model building, and SharePoint file management for BGP."/>
  <IconUrl DefaultValue="https://bgp-wip-app-production-efac.up.railway.app/icon-192.png"/>
  <HighResolutionIconUrl DefaultValue="https://bgp-wip-app-production-efac.up.railway.app/icon-192.png"/>
  <SupportUrl DefaultValue="https://bgp-wip-app-production-efac.up.railway.app/help"/>
  <AppDomains>
    <AppDomain>https://bgp-wip-app-production-efac.up.railway.app</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="ExcelApi" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://bgp-wip-app-production-efac.up.railway.app/addin/excel"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
